<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'SCD | Historial'</title>
    <link rel="icon" href="#">
    <link rel="stylesheet" href="#">
    <link rel="stylesheet" href="#">
    <link rel="stylesheet" href="#">
</head>
<body>
    <div class="container">
        <!-- Sidebar -->
        <%- include('../partials/sidebar', { usuario: usuario, paginaActiva: 'director-historial' }) %>

        <main class="content">
            <header>
                <h1>Bienvenido, <%= usuario ? usuario.nombre: 'Director' %></h1>
                <p>Panel principal del Historial</p>
            </header>

            <!-- Tabla Historial -->
            <section class="table">
                <table>
                    <thead>
                        <tr>
                            <th>Tipo Inventario</th>
                            <th>Fecha envio</th>
                            <th>Hora envio</th>
                            <th>Fecha A/R</th>
                            <th>Hora A/R</th>
                            <th>Estado</th>
                        </tr>
                    </thead>

                    <tbody>
                        <% if (typeof historial !== 'undefinied' && historial.length > 0) { %>
                            <% historial.forEach(item => { %>
                                <tr>
                                    <td><%= item.tipoInventario %></td>
                                    <td><%= item.fechaEnvio %></td>
                                    <td><%= item.horaEnvio %></td>
                                    <td><%= item.fechaAR || '-' %></td>
                                    <td><%= item.horaAR || '-' %></td>
                                    <td>
                                        <span class="status <%= item.estado.toLowerCase() %>">
                                            <%= item.estado %>
                                        </span>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" style="text-align: center;">
                                    No hay registros disponibles en el Historial.
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </section>
        </main>
    </div>

    <!-- Modal perfil -->
    <%- include('../partials/modalPerfil', { usuario: usuario }) %>

    <!-- Scripts -->
    <script src="/public/js/sidebar.js"></script>
    <script src="/public/js/modalPerfil.js"></script>
</body>
</html>
